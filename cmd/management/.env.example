# Server
GOFF_MGMT_SERVER_PORT=8080

# Database
GOFF_MGMT_DB_URL=postgres://goff:goff@localhost:5432/goff_mgmt?sslmode=disable

# OIDC (Keycloak local realm "goff", client "goff-mgmt")
GOFF_MGMT_OIDC_ISSUER=http://localhost:8081/realms/goff
GOFF_MGMT_OIDC_CLIENTID=goff-mgmt
GOFF_MGMT_OIDC_CLIENTSECRET=goff-mgmt-secret
GOFF_MGMT_OIDC_REDIRECTURL=http://localhost:8080/auth/callback

# Session JWT (must be >=32 chars in production; this is a dev value)
GOFF_MGMT_AUTH_JWTSECRET=dev-secret-change-me-dev-secret-change-me
GOFF_MGMT_AUTH_COOKIESECURE=false
GOFF_MGMT_AUTH_ADMINEMAILS=admin@local

# Logging
GOFF_MGMT_LOG_LEVEL=debug
GOFF_MGMT_LOG_FORMAT=console
